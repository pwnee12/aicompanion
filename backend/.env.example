# Environment configuration for AI Companion

# === Security ===
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./aicompanion.db

# === Vector Database ===
VECTOR_DB_TYPE=chroma
CHROMA_DB_PATH=./vector_db

# === LLM Configuration ===
# Options: openai, anthropic, ollama, hybrid
LLM_PROVIDER=hybrid

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# === Image Generation ===
# Options: stability, replicate, local_sd
IMAGE_PROVIDER=replicate

REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# Local Stable Diffusion
SD_MODEL_ID=runwayml/stable-diffusion-v1-5
SD_USE_LORA=true
SD_LORA_PATH=./models/lora

# === TTS (Text-to-Speech) ===
# Options: edge, coqui, gtts
TTS_PROVIDER=edge
TTS_DEFAULT_VOICE=en-US-AriaNeural
TTS_DEFAULT_RATE=150

# === File Storage ===
ASSETS_PATH=./assets
IMAGES_PATH=./assets/images
VOICES_PATH=./assets/voices
CHARACTERS_PATH=./assets/characters

# === Memory Settings ===
MEMORY_TOP_K=5
MEMORY_SIMILARITY_THRESHOLD=0.7

# === API Settings ===
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
DEBUG=true
