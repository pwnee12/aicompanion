# AI Companion - Docker Environment Configuration
# Copia este archivo a .env y ajusta las variables

# === Security ===
# Genera una clave segura: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production

# === LLM Configuration ===
# Options: openai, anthropic, ollama, hybrid
LLM_PROVIDER=hybrid

# OpenAI (Required for hybrid mode)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama (Optional - for local models)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama2

# === Image Generation ===
# Options: stability, replicate
IMAGE_PROVIDER=replicate

REPLICATE_API_TOKEN=r8-your-replicate-token-here
STABILITY_API_KEY=sk-your-stability-key-here

# === TTS (Text-to-Speech) ===
TTS_PROVIDER=edge
TTS_DEFAULT_VOICE=en-US-AriaNeural
TTS_DEFAULT_RATE=150

# === API Settings ===
DEBUG=false

# === Ports ===
FRONTEND_PORT=3000
BACKEND_PORT=8000
